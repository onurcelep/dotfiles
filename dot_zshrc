# ~/.zshrc — zsh interactive configuration (no oh-my-zsh)

# --- 1. Machine-local early setup (puts brew in PATH) ---
[[ -f ~/.zshenv.local ]] && source ~/.zshenv.local

# --- User PATH additions ---
[[ -d "$HOME/.atuin/bin" ]] && export PATH="$HOME/.atuin/bin:$PATH"
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"

# --- 2. Detect brew prefix ---
if command -v brew &>/dev/null; then
  BREW_PREFIX=$(brew --prefix)
fi

# --- 3. Completions ---
# zsh-completions from brew/system
[[ -n "$BREW_PREFIX" && -d "$BREW_PREFIX/share/zsh-completions" ]] && FPATH="$BREW_PREFIX/share/zsh-completions:$FPATH"
[[ -d /usr/share/zsh/vendor-completions ]] && FPATH="/usr/share/zsh/vendor-completions:$FPATH"

# Docker completions — cached, regenerated when docker binary changes
if command -v docker &>/dev/null; then
  _docker_comp_dir="$HOME/.cache/zsh/completions"
  _docker_comp_file="$_docker_comp_dir/_docker"
  _docker_bin="$(command -v docker)"
  if [[ ! -f "$_docker_comp_file" ]] || [[ "$_docker_bin" -nt "$_docker_comp_file" ]]; then
    mkdir -p "$_docker_comp_dir"
    docker completion zsh > "$_docker_comp_file" 2>/dev/null
  fi
  FPATH="$_docker_comp_dir:$FPATH"
  unset _docker_comp_dir _docker_comp_file _docker_bin
fi

# Initialize completions with daily cache
autoload -Uz compinit
if [[ -n "$HOME/.zcompdump"(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# AWS completion via bashcompinit (must come after compinit)
autoload -Uz bashcompinit && bashcompinit
if command -v aws_completer &>/dev/null; then
  complete -C aws_completer aws
fi

# Completion styling
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' special-dirs true
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*:warnings' format '%F{red}-- no matches found --%f'

# --- 4. History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY
setopt APPEND_HISTORY

# --- 5. Shell options ---
setopt AUTO_CD
setopt EXTENDED_GLOB
setopt INTERACTIVE_COMMENTS
setopt NO_BEEP
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT

# --- 6. Key bindings ---
bindkey -e                                       # emacs mode
bindkey '^[[A'  history-beginning-search-backward # Up arrow: prefix search
bindkey '^[[B'  history-beginning-search-forward  # Down arrow: prefix search
bindkey '^[[H'  beginning-of-line                 # Home
bindkey '^[[F'  end-of-line                       # End
bindkey '^[[1;5C' forward-word                    # Ctrl-Right
bindkey '^[[1;5D' backward-word                   # Ctrl-Left
autoload -z edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line                  # Ctrl-x Ctrl-e: edit in $EDITOR

# --- 7. fzf integration ---
eval "$(fzf --zsh 2>/dev/null)" || { [[ -f "$HOME/.fzf.zsh" ]] && source "$HOME/.fzf.zsh"; }

# --- 8. Shared aliases and functions ---
[[ -f ~/.shell_common ]] && source ~/.shell_common

# --- 9. zsh-autosuggestions ---
for f in \
  "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"; do
  [[ -f "$f" ]] && source "$f" && break
done

# --- 10. zsh-syntax-highlighting (must source before atuin to avoid widget interference) ---
for f in \
  "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"; do
  [[ -f "$f" ]] && source "$f" && break
done

# --- 11. Starship prompt ---
eval "$(starship init zsh)"

# --- 12. zoxide ---
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# --- 13. atuin (must be last — overrides fzf's ^R binding) ---
command -v atuin &>/dev/null && eval "$(atuin init zsh)"
