# --- Detect brew prefix (macOS Intel vs ARM, or absent) ---
if command -v brew &>/dev/null; then
  BREW_PREFIX=$(brew --prefix)
fi

# --- Machine-local overrides ---
[[ -f ~/.zshenv.local ]] && source ~/.zshenv.local

# --- Bitwarden unlock helper ---
bwu() { export BW_SESSION=$(bw unlock --raw); }

# --- zsh-completions (must be before Oh My Zsh) ---
[[ -d "$BREW_PREFIX/share/zsh-completions" ]] && FPATH="$BREW_PREFIX/share/zsh-completions:$FPATH"
[[ -d /usr/share/zsh/vendor-completions ]]    && FPATH="/usr/share/zsh/vendor-completions:$FPATH"

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git docker aws zoxide fzf)
[[ -d "$ZSH" ]] && source "$ZSH/oh-my-zsh.sh"

# --- General ---
export EDITOR='nano'
export LANG=en_US.UTF-8

# --- History ---
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS   # no duplicate entries
setopt HIST_FIND_NO_DUPS      # no duplicates in search
setopt HIST_REDUCE_BLANKS     # remove extra blanks
setopt SHARE_HISTORY          # share history across sessions
setopt APPEND_HISTORY         # append instead of overwrite

# --- Shell options ---
setopt AUTO_CD                # type directory name to cd into it
setopt EXTENDED_GLOB          # advanced globbing patterns
setopt INTERACTIVE_COMMENTS   # allow comments in interactive shell
setopt NO_BEEP                # no terminal beep

# --- bat ---
if command -v bat &>/dev/null; then
  alias cat="bat"
  alias catp="bat --plain"
  alias batdiff="bat --diff"
  alias bathelp="bat --plain --language=help"
  export BAT_THEME="Dracula"
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# --- eza ---
if command -v eza &>/dev/null; then
  alias ls="eza --icons"
  alias ll="eza -la --icons --git"
  alias la="eza -a --icons"
  alias tree="eza --tree --icons"
  alias lt="eza -la --icons --sort=modified --reverse"
fi

# --- zoxide ---
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# --- trash (safe rm) ---
if command -v trash &>/dev/null; then
  alias rm="trash"
elif [[ -x "$BREW_PREFIX/opt/trash/bin/trash" ]]; then
  export PATH="$BREW_PREFIX/opt/trash/bin:$PATH"
  alias rm="trash"
fi

# --- fzf + fd + bat ---
if command -v fzf &>/dev/null; then
  export FZF_DEFAULT_OPTS="--height 60% --layout=reverse --border --info=inline"
  export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window=up:3:wrap"

  if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND="fd --hidden --follow --exclude .git"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
  fi

  if command -v bat &>/dev/null; then
    export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"
  fi

  if command -v eza &>/dev/null; then
    export FZF_ALT_C_OPTS="--preview 'eza --tree --icons --level=2 {}'"
  fi
fi

# --- fzf helpers ---
if command -v fzf &>/dev/null; then
  # frg: fuzzy ripgrep - interactive grep, then open in editor
  if command -v rg &>/dev/null; then
    frg() {
      local result
      result=$(rg --color=always --line-number --no-heading "$@" |
        fzf --ansi --delimiter : \
            --preview 'bat --color=always --highlight-line {2} {1}' \
            --preview-window '~3:+{2}+3/2')
      [[ -n "$result" ]] || return
      local file line
      file=$(echo "$result" | awk -F: '{print $1}')
      line=$(echo "$result" | awk -F: '{print $2}')
      $EDITOR +"$line" "$file" </dev/tty
    }
  fi

  # fkill: fuzzy kill process
  fkill() {
    ps -ef | sed 1d | fzf -m --header='[kill process]' | awk '{print $2}' | xargs kill -${1:-9}
  }

  # fbr: fuzzy git branch checkout
  fbr() {
    git branch --all --sort=-committerdate |
      fzf --header='[git checkout]' --preview 'git log --oneline --graph --color=always {1} -- | head -20' |
      sed 's/remotes\/origin\///' | xargs git checkout
  }

  # flog: fuzzy git log browser
  flog() {
    git log --oneline --color=always --decorate |
      fzf --ansi --preview 'git show --color=always {1}' |
      awk '{print $1}' | xargs git show
  }
fi

# --- ripgrep ---
command -v rg &>/dev/null && export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"

# --- zsh-autosuggestions & syntax-highlighting (must be at end) ---
# Check brew paths, then common Linux paths
for f in \
  "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"; do
  [[ -f "$f" ]] && source "$f" && break
done

for f in \
  "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"; do
  [[ -f "$f" ]] && source "$f" && break
done
